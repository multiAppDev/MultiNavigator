<Window x:Class="Multinavigator.NotasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:Multinavigator.Idiomas"
        Title="{Binding Source={StaticResource IdiomaGlobal}, Path=Notas_WindowTitle}" Height="600" Width="620"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Notas_NewNote}" Click="BtnNuevaNota_Click"
                    Background="#4B96EA" Foreground="White"
                    BorderThickness="0" Padding="15,8"
                    HorizontalAlignment="Left">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ListaNotas" Margin="10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,5" Padding="12" CornerRadius="8"
                                BorderBrush="#DDD" BorderThickness="1" Background="White">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <TextBlock Text="{Binding Fecha, StringFormat='{}{0:dd/MM/yyyy}'}"
                                               FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                                    <Button Content="🗑" HorizontalAlignment="Right"
                                            Background="Transparent" BorderThickness="0"
                                            FontSize="14" Foreground="#CC0000"
                                            Tag="{Binding}" Click="BtnEliminar_Click"/>
                                </Grid>

                                <TextBox Grid.Row="1" Text="{Binding Texto, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent"
                                         TextWrapping="Wrap" Margin="0,6,0,6"
                                         FontSize="13" AcceptsReturn="True"
                                         LostFocus="NotaTexto_LostFocus" Tag="{Binding}"/>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Notas_Reminder}"
                                              IsChecked="{Binding AvisoActivo}"
                                              VerticalAlignment="Center" Margin="0,0,8,0"
                                              Checked="Aviso_Changed" Unchecked="Aviso_Changed"
                                              Tag="{Binding}"/>

                                    <DatePicker Grid.Column="1"
                                                SelectedDate="{Binding FechaAviso}"
                                                FontSize="11"
                                                SelectedDateChanged="FechaAviso_Changed"
                                                Tag="{Binding}">
                                        <DatePicker.Style>
                                            <Style TargetType="DatePicker">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AvisoActivo}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DatePicker.Style>
                                    </DatePicker>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
