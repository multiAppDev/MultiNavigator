<Window x:Class="Multinavigator.FavoritesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:Multinavigator.Idiomas"
        Title="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_WindowTitle}"
        Height="580" 
        Width="920" 
        MinHeight="420" 
        MinWidth="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="TB" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TB_Blue" TargetType="Button" BasedOn="{StaticResource TB}">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1565C0"/>
        </Style>
        <Style x:Key="TB_Red" TargetType="Button" BasedOn="{StaticResource TB}">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#B71C1C"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar 1: CRUD + abrir ── -->
        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="1"
                CornerRadius="5" Padding="8,5" Margin="0,0,0,5">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_Add}"    Style="{StaticResource TB_Blue}" Click="Add_Click"/>
                    <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_Edit}"   Style="{StaticResource TB}"      Click="Edit_Click"/>
                    <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_Delete}" Style="{StaticResource TB_Red}"  Click="Delete_Click"/>
                    <Rectangle Width="1" Fill="#BBB" Margin="2,4"/>
                    <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_Up}"     Style="{StaticResource TB}"      Click="MoveUp_Click"/>
                    <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_Down}"   Style="{StaticResource TB}"      Click="MoveDown_Click"/>
                    <Rectangle Width="1" Fill="#BBB" Margin="2,4"/>
                    <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_Open}"   Style="{StaticResource TB}"      Click="Open_Click"
                            ToolTip="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_OpenTooltip}"/>
                    <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_CopyUrl}" Style="{StaticResource TB}"     Click="CopyUrl_Click"/>
                </StackPanel>
                <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_Close}" Style="{StaticResource TB}"
                        HorizontalAlignment="Right" Click="Close_Click" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <!-- ── Toolbar 2: Import / Export / Navegadores ── -->
        <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="1"
                CornerRadius="5" Padding="8,5" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_Export}" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_ExportHtml}" Style="{StaticResource TB}" Click="ExportHtml_Click"
                        ToolTip="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_ExportHtmlTooltip}"/>
                <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_ExportJson}" Style="{StaticResource TB}" Click="ExportJson_Click"/>
                <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_ExportCsv}"  Style="{StaticResource TB}" Click="ExportCsv_Click"/>

                <Rectangle Width="1" Fill="#BBB" Margin="4,3"/>

                <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_Import}" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_ImportHtml}" Style="{StaticResource TB}" Click="ImportHtml_Click"
                        ToolTip="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_ImportHtmlTooltip}"/>
                <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_ImportJson}" Style="{StaticResource TB}" Click="ImportJson_Click"/>

                <Rectangle Width="1" Fill="#BBB" Margin="4,3"/>

                <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_ImportFrom}" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="ComboBrowsers" Height="26" MinWidth="120" Margin="0,0,5,0"
                          VerticalContentAlignment="Center"/>
                <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_ImportBtn}" Height="26" MinWidth="70"
                        Style="{StaticResource TB}" Click="ImportBrowser_Click"/>
            </StackPanel>
        </Border>

        <!-- ── Toolbar 3: Búsqueda / Filtro ── -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="1"
                CornerRadius="5" Padding="8,5" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_Search}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   Grid.Column="1" x:Name="SearchBox" Height="26"
                           VerticalContentAlignment="Center" Padding="4,0"
                           TextChanged="SearchBox_TextChanged"/>
                <TextBlock Grid.Column="2" Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_Group}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox  Grid.Column="3" x:Name="GroupFilter" Height="26"
                           SelectionChanged="GroupFilter_SelectionChanged"/>
                <Button    Grid.Column="4" Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_Clear}"
                           Height="26" MinWidth="55" Margin="5,0,0,0"
                           Style="{StaticResource TB}" Click="ClearFilter_Click"/>
            </Grid>
        </Border>

        <!-- ── DataGrid ── -->
        <DataGrid x:Name="FavoritesGrid" Grid.Row="3"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#DBDBDB"
                  AlternatingRowBackground="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"
                  RowHeight="28" FontSize="12"
                  MouseDoubleClick="FavoritesGrid_DoubleClick">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_ColTitle}" Width="2*" SortMemberPath="Title">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="{Binding FaviconImage}"
                                       Width="16" Height="16" Margin="2,0,6,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="3*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_ColGroup}" Binding="{Binding Folder}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_CtxOpen}"   Click="Open_Click"/>
                    <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_CtxEdit}"   Click="Edit_Click"/>
                    <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_CtxCopy}"   Click="CopyUrl_Click"/>
                    <Separator/>
                    <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Fav_CtxDelete}" Click="Delete_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <!-- ── Status bar ── -->
        <Border Grid.Row="4" Background="#EEE" BorderBrush="#DDD"
                BorderThickness="0,1,0,0" Padding="8,3" Margin="0,5,0,0">
            <DockPanel>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontSize="11" Foreground="#757575"/>
                <TextBlock x:Name="CountText"  HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" Foreground="#757575"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
