<Window x:Class="Multinavigator.CookieManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Multinavigator"
        xmlns:res="clr-namespace:Multinavigator.Idiomas"
        Title="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_WindowTitle}"
        Height="647"
        Width="950"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FAFAFA">

    <Window.Resources>
        <local:FaviconConverter x:Key="FaviconConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- BARRA SUPERIOR -->
        <Border Background="#FFFFFF"
                Padding="10"
                CornerRadius="6"
                BorderBrush="#DDD"
                BorderThickness="1"
                Margin="0 0 0 12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_SearchDomain}"
                           VerticalAlignment="Center"
                           Margin="0 0 8 0"
                           FontWeight="SemiBold"/>
                <TextBox x:Name="SearchTextBox"
                         Width="260" Height="28" Margin="0 0 12 0"
                         Padding="5" VerticalContentAlignment="Center"
                         BorderBrush="#CCC" BorderThickness="1" Background="#FFF"
                         TextChanged="SearchTextBox_TextChanged"/>
                <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_Reload}"
                        Padding="12 4"
                        Background="#4A90E2" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="ReloadButton_Click"/>
            </StackPanel>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2.2*"/>
            </Grid.ColumnDefinitions>

            <!-- DOMINIOS -->
            <GroupBox Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_Domains}"
                      Margin="0 0 12 0" FontWeight="Bold">
                <Border Padding="5">
                    <ListBox x:Name="DomainsListBox"
                             SelectionChanged="DomainsListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0 2">
                                    <Image Width="16" Height="16" Margin="0 0 6 0"
                                           Source="{Binding Domain, Converter={StaticResource FaviconConverter}}"/>
                                    <TextBlock>
                                        <Run Text="{Binding Domain, Mode=OneWay}"/>
                                        <Run Text=" ("/>
                                        <Run Text="{Binding Count, Mode=OneWay}"/>
                                        <Run Text=")"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </GroupBox>

            <!-- COOKIES -->
            <GroupBox Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_Cookies}"
                      Grid.Column="1" Margin="0 0 12 0" FontWeight="Bold">
                <StackPanel Margin="5">
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                        <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_SearchCookie}"
                                   VerticalAlignment="Center" Margin="0 0 6 0"/>
                        <TextBox x:Name="CookieSearchTextBox"
                                 Width="200" Padding="4"
                                 TextChanged="CookieSearchTextBox_TextChanged"/>
                    </StackPanel>

                    <DataGrid x:Name="CookiesDataGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              BorderBrush="#DDD" BorderThickness="1"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              SelectionChanged="CookiesDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_ColName}"
                                                Binding="{Binding Name, Mode=OneWay}" Width="*"/>
                            <DataGridTextColumn Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_ColValue}"
                                                Binding="{Binding Value, Mode=OneWay}" Width="2*"/>
                            <DataGridTextColumn Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_ColPath}"
                                                Binding="{Binding Path, Mode=OneWay}" Width="*"/>
                            <DataGridTextColumn Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_ColExpires}"
                                                Binding="{Binding Expires, Mode=OneWay}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </GroupBox>

            <!-- DETALLES -->
            <GroupBox Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_Details}"
                      Grid.Column="2" FontWeight="Bold">
                <StackPanel Margin="10">

                    <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_DetailName}" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DetailNameTextBlock" Margin="0 0 0 8"/>

                    <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_DetailValue}" FontWeight="SemiBold"/>
                    <TextBox x:Name="DetailValueTextBox"
                             Margin="0 0 0 8" Height="70" Padding="5"
                             TextWrapping="Wrap" IsReadOnly="True" BorderBrush="#CCC"/>

                    <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_CopyValue}"
                            Padding="8 3" Margin="0 0 0 8"
                            Background="#5BC0DE" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="CopyCookieValueButton_Click"/>

                    <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_EditCookie}"
                            Padding="8 3" Margin="0 0 0 12"
                            Background="#5CB85C" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="EditCookieButton_Click"/>

                    <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_DetailDomain}" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DetailDomainTextBlock" Margin="0 0 0 8"/>

                    <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_DetailPath}" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DetailPathTextBlock" Margin="0 0 0 8"/>

                    <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_DetailExpires}" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DetailExpiresTextBlock" Margin="0 0 0 8"/>

                    <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_DetailFlags}" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DetailFlagsTextBlock" Margin="0 0 0 8"/>

                    <StackPanel Margin="0 12 0 0">
                        <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_DeleteCookie}"
                                Padding="10 4" Margin="0 0 8 0"
                                Background="#D9534F" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="DeleteCookieButton_Click"/>
                        <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_DeleteDomain}"
                                Padding="10 4" Margin="0 10 8 0"
                                Background="#F0AD4E" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="DeleteDomainCookiesButton_Click"/>
                    </StackPanel>

                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- BARRA INFERIOR -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 12 0 0">
            <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_DeleteAll}"
                    Padding="12 4" Margin="0 0 10 0"
                    Background="#C9302C" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="DeleteAllCookiesButton_Click"/>
            <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Cookie_Close}"
                    Width="90" Padding="8 4"
                    Background="#777" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
