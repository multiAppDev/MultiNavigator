                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Circle" Property="Fill" Value="#22888888"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <Path Data="M 4,0 H 12" Stroke="{DynamicResource TabTextBrush}" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>

                            <!-- MAXIMIZAR -->
                            <Button x:Name="BtnMaxRestore" Click="BtnMaximize_Click" Width="46" VerticalAlignment="Stretch"
                                    BorderThickness="0" Background="Transparent">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid>
                                                        <Ellipse x:Name="Circle" Width="28" Height="28" Fill="Transparent"/>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Circle" Property="Fill" Value="#22888888"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <Path Data="M 1,1 H 9 V 9 H 1 Z" Stroke="{DynamicResource TabTextBrush}" StrokeThickness="1.5"
                                      Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>

                            <!-- CERRAR -->
                            <Button Click="BtnClose_Click" Width="46" VerticalAlignment="Stretch"
                                    BorderThickness="0" Background="Transparent">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid>
                                                        <Ellipse x:Name="Circle" Width="28" Height="28" Fill="Transparent"/>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Circle" Property="Fill" Value="#C62828"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <Path Data="M 2,2 L 10,10 M 10,2 L 2,10" Stroke="{DynamicResource TabTextBrush}" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>

                        </StackPanel>


                        <!-- BOTONES PANEL + MENÚ (centrados) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                            <!-- MENÚ HAMBURGUESA -->
                            <Button x:Name="BtnHamburguesa" Width="32" Height="32" Margin="0,0,20,0" Click="BtnMenu_Click"
                                    BorderThickness="0"
                                    Foreground="{DynamicResource ButtonAccentBrush}"
                                    Background="{DynamicResource TabActiveBrush}"
                                    Style="{StaticResource DefaultButtonStyle}" Cursor="Hand">
                                <StackPanel VerticalAlignment="Center">
                                    <Rectangle Fill="{DynamicResource ButtonAccentBrush}" Width="14" Height="1.8" Margin="0,2"/>
                                    <Rectangle Fill="{DynamicResource ButtonAccentBrush}" Width="14" Height="1.8" Margin="0,2"/>
                                    <Rectangle Fill="{DynamicResource ButtonAccentBrush}" Width="14" Height="1.8" Margin="0,2"/>
                                </StackPanel>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_MenuGeneral}" Tag="0" Click="OpenSettings_Click">
                                            <MenuItem.Icon>
                                                <Canvas Width="14" Height="14">
