<Window x:Class="Multinavigator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:Multinavigator"
        xmlns:res="clr-namespace:Multinavigator.Idiomas"
        mc:Ignorable="d"
        Title="Multinavigator"
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#01000000"
        AllowsTransparency="true"
        MouseMove="Window_MouseMove"
        MouseUp="Window_MouseUp"
        WindowStyle="none"
        ResizeMode="CanResize">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" 
                      CornerRadius="0"
                      GlassFrameThickness="1" 
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <local:FaviconConverter x:Key="FaviconConverter" />

        <Style x:Key="NavBarStyle" TargetType="ContentControl">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="DefaultButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="active"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background"
                                        Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </MultiTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource ButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PLANTILLA DE CONTENIDO PARA BARRA DE NAVEGACIÓN -->
        <DataTemplate x:Key="NavigationBarTemplate">
            <Grid Margin="0,-1,0,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Background" Value="{DynamicResource NavBarBackgroundBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsIncognito}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource IncognitoActiveBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="34"/>
                    <ColumnDefinition Width="Auto" MinWidth="34"/>
                    <ColumnDefinition Width="Auto" MinWidth="34"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>

                <!-- BACK -->
                <Button Grid.Column="0"
                        Tag="{Binding}"
                        Style="{StaticResource DefaultButtonStyle}"
                        BorderThickness="0"
                        Click="Back_Click"
                        Margin="0,0,1,0">
                    <Path Fill="{DynamicResource ButtonAccentBrush}"
                          Data="M3,4 C5,10 5,15 3,21 L20,12 Z"
                          Height="12"
                          Stretch="Fill"
                          Width="19"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="180"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>
                </Button>

                <!-- FORWARD -->
                <Button Grid.Column="1"
                        Tag="{Binding}"
                        Style="{StaticResource DefaultButtonStyle}"
                        BorderThickness="0"
                        Click="Forward_Click">
                    <Path Fill="{DynamicResource ButtonAccentBrush}"
                          Data="M3,4 C5,10 5,15 3,21 L20,12 Z"
                          HorizontalAlignment="Left"
                          Height="12"
                          Stretch="Fill"
                          VerticalAlignment="Center"
                          Width="19"/>
                </Button>

                <!-- RELOAD -->
                <Button Grid.Column="2"
                        Tag="{Binding}"
                        Style="{StaticResource DefaultButtonStyle}"
                        BorderThickness="0"
                        Click="Reload_Click">
                    <Path Fill="{DynamicResource ButtonAccentBrush}"
                          Stroke="{DynamicResource ButtonAccentBrush}"
                          Data="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Height="15"
                          Stretch="Fill"
                          Width="15"/>
                </Button>

                <!-- SECURE ICON -->
                <Path x:Name="SecureIconTemplate"
                      Margin="10,10,10,10"
                      Fill="#e0cc4c"
                      Visibility="Visible"
                      Data="M12 17c1.1 0 2-.9 2-2v-5c0-1.1-.9-2-2-2V7c0-2.21-1.79-4-4-4S4 4.79 4 7v1c-1.1 0-2 .9-2 2v5c0 1.1.9 2 2 2h8zm-6-9V7c0-1.1.9-2 2-2s2 .9 2 2v1H6z"
                      Grid.Column="3"
                      Stretch="Fill"
                      Height="12"
                      Width="10"
                      Cursor="Hand"
                      MouseLeftButtonUp="LockIcon_Click">
                    <Path.ToolTip>
                        <ToolTip x:Name="SecureTooltip"/>
                    </Path.ToolTip>
                </Path>

                <!-- URL TEXTBOX -->
                <TextBox Grid.Column="4"
                         x:Name="UrlTemplate"
                         Tag="{Binding}"
                         FontSize="13"
                         PreviewKeyDown="Url_PreviewKeyDown"
                         TextChanged="Url_TextChanged"
                         MouseDoubleClick="UrlBox_MouseDoubleClick"
                         GotFocus="UrlBox_GotFocus"
                         PreviewMouseLeftButtonDown="UrlBox_PreviewMouseLeftButtonDown"
                         BorderThickness="0"
                         Background="{DynamicResource UrlBoxBackgroundBrush}"
                         Foreground="{DynamicResource UrlBoxForegroundBrush}"
                         Padding="8,3,0,6"
                         Margin="0,4,0,4">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="7"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- ⭐ FAVORITOS -->
                <Button Grid.Column="5"
                        x:Name="BtnStarTemplate"
                        Tag="{Binding PanelId}"
                        Height="30"
                        Style="{StaticResource DefaultButtonStyle}"
                        BorderThickness="0"
                        Click="BtnStar_Click">
                    <Path Fill="{DynamicResource ButtonAccentBrush}"
                          IsHitTestVisible="False"
                          Data="M13 4.5 L15.8 9.7 L21.2 10.6 L17.1 14.9 L18.0 20.4 L13 17.3 L8 20.4 L8.9 14.9 L4.8 10.6 L10.2 9.7 Z"
                          Width="12" Height="12"
                          Stretch="Fill"/>
                </Button>

                <!-- ⭐ OPCIONES -->
                <Button Grid.Column="6"
                        x:Name="BtnMenuOpciones"
                        Style="{StaticResource DefaultButtonStyle}"
                        BorderThickness="0"
                        Tag="{Binding WebView}"
                        ContextMenu="{x:Null}"
                        PreviewMouseLeftButtonDown="AbrirMenuCompartido"
                        Click="BtnMenuOpciones_Click"
                        Cursor="Hand">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Width="4" Height="4" Fill="{DynamicResource ButtonAccentBrush}" Margin="0,1"/>
                        <Ellipse Width="4" Height="4" Fill="{DynamicResource ButtonAccentBrush}" Margin="0,1"/>
                        <Ellipse Width="4" Height="4" Fill="{DynamicResource ButtonAccentBrush}" Margin="0,1"/>
                    </StackPanel>
                </Button>

            </Grid>
        </DataTemplate>

        <!-- MENÚ CONTEXTUAL COMPARTIDO -->
        <ContextMenu x:Key="SharedContextMenu" Placement="MousePoint">
            <ContextMenu.Resources>
                <Style TargetType="{x:Type MenuItem}">
                    <Setter Property="DataContext" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Setter Property="Tag" Value="{Binding}"/>
                </Style>
                </ContextMenu.Resources>

                <!-- SIN MARCAR -->
            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxClearMark}"
                      Click="Menu_ClearMark_Click"
                      Tag="{Binding}">
                <MenuItem.Icon>
                    <Canvas Width="12" Height="12">
                        <Rectangle Width="12" Height="12"
                                   Stroke="#BBBBBB"
                                   StrokeThickness="1.5"
                                   Fill="Transparent"/>
                        <Line X1="1" Y1="1" X2="11" Y2="11"
                              Stroke="#FF0000"
                              StrokeThickness="1.5"/>
                    </Canvas>
                </MenuItem.Icon>
            </MenuItem>

            <!-- COLORES -->
            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxMarkColor}">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Ellipse Width="4" Height="4" Canvas.Left="1" Canvas.Top="5" Fill="#FFff3066"/>
                        <Ellipse Width="4" Height="4" Canvas.Left="5" Canvas.Top="5" Fill="#FF00ff00"/>
                        <Ellipse Width="4" Height="4" Canvas.Left="9" Canvas.Top="5" Fill="#FF2088ff"/>
                    </Canvas>
                </MenuItem.Icon>
                <MenuItem.ItemsSource>
                    <x:Array Type="{x:Type SolidColorBrush}">
                        <SolidColorBrush Color="#FFff0000"/>
                        <SolidColorBrush Color="#FFffaa00"/>
                        <SolidColorBrush Color="#FFffff00"/>
                        <SolidColorBrush Color="#FFff00ff"/>
                        <SolidColorBrush Color="#FF00ff00"/>
                        <SolidColorBrush Color="#FF00ffff"/>
                        <SolidColorBrush Color="#FF0000ff"/>
                        <SolidColorBrush Color="#FFEF5350"/>
                        <SolidColorBrush Color="#FFFF7043"/>
                        <SolidColorBrush Color="#FFFFCA28"/>
                        <SolidColorBrush Color="#FF66BB6A"/>
                        <SolidColorBrush Color="#FF26A69A"/>
                        <SolidColorBrush Color="#FF42A5F5"/>
                        <SolidColorBrush Color="#FF5C6BC0"/>
                        <SolidColorBrush Color="#FFAB47BC"/>
                        <SolidColorBrush Color="#FFEC407A"/>
                        <SolidColorBrush Color="#FF8D6E63"/>
                        <SolidColorBrush Color="#FFBDBDBD"/>
                        <SolidColorBrush Color="#FF616161"/>
                        <SolidColorBrush Color="#FF000000"/>
                    </x:Array>
                </MenuItem.ItemsSource>
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Color}"/>
                        <Setter Property="Background" Value="{Binding}"/>
                        <Setter Property="CommandParameter" Value="{Binding}"/>
                        <Setter Property="Tag"
                                Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <EventSetter Event="Click" Handler="Menu_SetMark_Click"/>
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>

            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxSortByColor}"
                      Click="Menu_GroupByColor_Click"
                      Tag="{Binding}">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Rectangle Canvas.Left="0"  Canvas.Top="0" Width="3" Height="14" Fill="#FFFF0000"/>
                        <Rectangle Canvas.Left="3"  Canvas.Top="0" Width="3" Height="14" Fill="#FFFFFF00"/>
                        <Rectangle Canvas.Left="6"  Canvas.Top="0" Width="3" Height="14" Fill="#FF00CC00"/>
                        <Rectangle Canvas.Left="9"  Canvas.Top="0" Width="3" Height="14" Fill="#FF0000FF"/>
                        <Rectangle Canvas.Left="12" Canvas.Top="0" Width="2" Height="14" Fill="#FFFF00FF"/>
                    </Canvas>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <!-- IR A PÁGINA DE INICIO -->
            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxGoHome}"
                      Click="MenuNav_IrInicio_Click"
                      Tag="{Binding}">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Path Data="M7 1L13 6v7H9V9H5v4H1V6L7 1z"
                              Fill="#666666"
                              Stroke="#666666"
                              StrokeThickness="0.5"/>
                    </Canvas>
                </MenuItem.Icon>
            </MenuItem>

            <!-- MODO INCÓGNITO -->
            <MenuItem Click="Menu_ToggleIncognito_Click"
                      Tag="{Binding}">
                <MenuItem.Icon>
                    <Viewbox Width="14" Height="14">
                        <Path Data="M2.54 1.22C2.66.52 3.27 0 3.98 0h6.04c.71 0 1.32.52 1.44 1.22l.71 4.28h1.05c.41 0 .75.34.75.75s-.34.75-.75.75H.78c-.41 0-.75-.34-.75-.75s.34-.75.75-.75h1.05l.71-4.28ZM8.75 10.9c0-.83.67-1.5 1.5-1.5.83 0 1.5.67 1.5 1.5 0 .83-.67 1.5-1.5 1.5-.83 0-1.5-.67-1.5-1.5Zm1.5-3c-1.06 0-2 .55-2.53 1.39-.22-.09-.46-.14-.72-.14-.26 0-.5.05-.72.14-.53-.83-1.47-1.39-2.53-1.39-1.66 0-3 1.34-3 3 0 1.66 1.34 3 3 3 1.66 0 3-1.34 3-3v-.01l.04-.13c.02-.04.03-.05.04-.06.01 0 .05-.03.16-.03.12 0 .16.03.16.03l.04.06.04.13v.04c.02 1.64 1.36 2.96 3 2.96 1.66 0 3-1.34 3-3 0-1.66-1.34-3-3-3ZM3.75 9.4c.82 0 1.48.65 1.5 1.46v.03c0 .01 0 .03.01.03-.02.81-.68 1.47-1.5 1.47-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5Z"
                              Fill="{DynamicResource {x:Static SystemColors.MenuTextBrushKey}}"
                              Stretch="Uniform"/>
                    </Viewbox>
                </MenuItem.Icon>
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxIncognitoOn}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsIncognito}" Value="True">
                                <Setter Property="Header" Value="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxIncognitoOff}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
            </MenuItem>

            <Separator/>

            <!-- RECARGAR -->
            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxReload}"
                      Tag="reload,this"
                      Click="Menu_TabAction">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Path Data="M7 2A5 5 0 1 0 12 7h-2A3 3 0 1 1 7 4V2z" Fill="#666666"/>
                        <Path Data="M7 0L10 3L7 6V0z" Fill="#666666"/>
                    </Canvas>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxOpenInWindow}" Click="Menu_AbrirEnNavegador_Click" Tag="{Binding}">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Rectangle Width="10" Height="8" Canvas.Left="1" Canvas.Top="3"
                                   Stroke="#666666" StrokeThickness="1.5" Fill="Transparent"/>
                        <Path Data="M8,1 H13 V6 M13,1 L7,7"
                              Stroke="#666666" StrokeThickness="1.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Fill="Transparent"/>
                    </Canvas>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxOpenWith}" Tag="{Binding}"
                      SubmenuOpened="Menu_AbrirCon_SubmenuOpened">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Rectangle Width="10" Height="8" Canvas.Left="1" Canvas.Top="3"
                                   Stroke="#666666" StrokeThickness="1.5" Fill="Transparent"/>
                        <Ellipse Width="4" Height="4" Canvas.Left="5" Canvas.Top="1" Fill="#666666"/>
                    </Canvas>
                </MenuItem.Icon>
                <MenuItem Header="_placeholder"/>
            </MenuItem>

            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxReopenClosed}" Click="ReopenLastClosedTab_Click">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Path Data="M7 2A5 5 0 1 1 2 7H4A3 3 0 1 0 7 4V2z" Fill="#666666"/>
                        <Path Data="M7 0L4 3L7 6V0z" Fill="#666666"/>
                    </Canvas>
                </MenuItem.Icon>
            </MenuItem>

            <!-- NUEVA PESTAÑA -->
            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxNewTab}">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Rectangle Width="10" Height="8" Canvas.Left="2" Canvas.Top="3"
                                   Stroke="#666666" StrokeThickness="1.5" Fill="Transparent"/>
                    </Canvas>
                </MenuItem.Icon>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_PosRight}"  Tag="new,right"  Click="Menu_TabAction"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_PosLeft}"   Tag="new,left"   Click="Menu_TabAction"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_PosEnd}"    Tag="new,end"    Click="Menu_TabAction"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_PosStart}"  Tag="new,start"  Click="Menu_TabAction"/>
            </MenuItem>

            <!-- NUEVA PESTAÑA INCÓGNITO -->
            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxNewIncognito}">
                <MenuItem.Icon>
                    <Viewbox Width="14" Height="14">
                        <Path Data="M2.54 1.22C2.66.52 3.27 0 3.98 0h6.04c.71 0 1.32.52 1.44 1.22l.71 4.28h1.05c.41 0 .75.34.75.75s-.34.75-.75.75H.78c-.41 0-.75-.34-.75-.75s.34-.75.75-.75h1.05l.71-4.28ZM8.75 10.9c0-.83.67-1.5 1.5-1.5.83 0 1.5.67 1.5 1.5 0 .83-.67 1.5-1.5 1.5-.83 0-1.5-.67-1.5-1.5Zm1.5-3c-1.06 0-2 .55-2.53 1.39-.22-.09-.46-.14-.72-.14-.26 0-.5.05-.72.14-.53-.83-1.47-1.39-2.53-1.39-1.66 0-3 1.34-3 3 0 1.66 1.34 3 3 3 1.66 0 3-1.34 3-3v-.01l.04-.13c.02-.04.03-.05.04-.06.01 0 .05-.03.16-.03.12 0 .16.03.16.03l.04.06.04.13v.04c.02 1.64 1.36 2.96 3 2.96 1.66 0 3-1.34 3-3 0-1.66-1.34-3-3-3ZM3.75 9.4c.82 0 1.48.65 1.5 1.46v.03c0 .01 0 .03.01.03-.02.81-.68 1.47-1.5 1.47-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5Z"
                              Fill="{DynamicResource {x:Static SystemColors.MenuTextBrushKey}}"
                              Stretch="Uniform"/>
                    </Viewbox>
                </MenuItem.Icon>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_PosRight}"  Tag="newincognito,right"  Click="Menu_TabAction"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_PosLeft}"   Tag="newincognito,left"   Click="Menu_TabAction"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_PosEnd}"    Tag="newincognito,end"    Click="Menu_TabAction"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_PosStart}"  Tag="newincognito,start"  Click="Menu_TabAction"/>
            </MenuItem>

            <!-- MOVER PESTAÑA A -->
            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxMoveTab}">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Path Data="M1,7 H13 M8,2 L13,7 L8,12"
                              Stroke="#666666" StrokeThickness="1.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Fill="Transparent"/>
                    </Canvas>
                </MenuItem.Icon>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_Browser1}" Tag="move,1" Click="Menu_MoveTab_Click"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_Browser2}" Tag="move,2" Click="Menu_MoveTab_Click"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_Browser3}" Tag="move,3" Click="Menu_MoveTab_Click"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_Browser4}" Tag="move,4" Click="Menu_MoveTab_Click"/>
            </MenuItem>

            <!-- COPIAR PESTAÑA EN -->
            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxCopyTab}">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Rectangle Width="7" Height="6" Canvas.Left="1" Canvas.Top="2"
                                   Stroke="#666666" StrokeThickness="1" Fill="Transparent"/>
                        <Rectangle Width="7" Height="6" Canvas.Left="6" Canvas.Top="6"
                                   Stroke="#666666" StrokeThickness="1" Fill="White"/>
                        <Line X1="10" Y1="2" X2="10" Y2="6" Stroke="#666666" StrokeThickness="1.5"/>
                        <Line X1="8" Y1="4" X2="12" Y2="4" Stroke="#666666" StrokeThickness="1.5"/>
                    </Canvas>
                </MenuItem.Icon>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_Browser1}" Tag="copy,1" Click="Menu_MoveTab_Click"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_Browser2}" Tag="copy,2" Click="Menu_MoveTab_Click"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_Browser3}" Tag="copy,3" Click="Menu_MoveTab_Click"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_Browser4}" Tag="copy,4" Click="Menu_MoveTab_Click"/>
            </MenuItem>

            <!-- DUPLICAR -->
            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxDuplicate}"
                      Tag="dup,right"
                      Click="Menu_TabAction">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Rectangle Width="7" Height="6" Canvas.Left="1" Canvas.Top="2"
                                   Stroke="#666666" StrokeThickness="1" Fill="Transparent"/>
                        <Rectangle Width="7" Height="6" Canvas.Left="6" Canvas.Top="6"
                                   Stroke="#666666" StrokeThickness="1" Fill="White"/>
                    </Canvas>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <!-- CERRAR -->
            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxClose}">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Line X1="3" Y1="3" X2="11" Y2="11"
                              Stroke="#666666" StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <Line X1="11" Y1="3" X2="3" Y2="11"
                              Stroke="#666666" StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>
                </MenuItem.Icon>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CloseThis}"
                          Tag="{Binding}"
                          Click="CloseTab_Click"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CloseAllRight}"
                          Tag="close,right"
                          Click="Menu_TabAction"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CloseAllLeft}"
                          Tag="close,left"
                          Click="Menu_TabAction"/>
                <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CloseOthers}"
                          Tag="close,others"
                          Click="Menu_TabAction"/>
            </MenuItem>

            <Separator/>

            <!-- RESTAURAR ÚLTIMA SESIÓN -->
            <MenuItem Header="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_CtxRestoreSession}"
                      Click="Menu_RestoreSession_Click">
                <MenuItem.Icon>
                    <Canvas Width="14" Height="14">
                        <Path Data="M7 2A5 5 0 1 0 12 7h-2A3 3 0 1 1 7 4V2z" Fill="#666666"/>
                        <Path Data="M7 0L10 3L7 6V0z" Fill="#666666"/>
                    </Canvas>
                </MenuItem.Icon>
            </MenuItem>

        </ContextMenu>

        <!-- Estilo del contenedor de pestaña -->
        <Style x:Key="TabItemContainerStyle" TargetType="ContentControl">
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource TabInactiveBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Grid>
                            <Border x:Name="TabShape"
                                    CornerRadius="10,10,0,0"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0"
                                    SnapsToDevicePixels="True"
                                    IsHitTestVisible="False"/>
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              Margin="7,4,4,4"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="{x:Null}"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabShape" Property="Background" Value="{DynamicResource TabHoverBrush}"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="Active"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabShape" Property="Background" Value="{DynamicResource TabActiveHoverBrush}"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="Incognito"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabShape" Property="Background" Value="{DynamicResource IncognitoHoverBrush}"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="IncognitoActive"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabShape" Property="Background" Value="{DynamicResource IncognitoActiveHoverBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TabActiveBrush}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Panel.ZIndex" Value="10"/>
                    <Setter Property="Margin" Value="0,0,4,-1"/>
                    <Setter Property="Padding" Value="8,4,8,5"/>
                    <Setter Property="Tag" Value="Active"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsIncognito}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource IncognitoInactiveBrush}"/>
                    <Setter Property="Tag" Value="Incognito"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsActive}" Value="True"/>
                        <Condition Binding="{Binding IsIncognito}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource IncognitoActiveBrush}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Panel.ZIndex" Value="10"/>
                    <Setter Property="Margin" Value="0,0,4,-1"/>
                    <Setter Property="Padding" Value="8,4,8,5"/>
                    <Setter Property="Tag" Value="IncognitoActive"/>
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                    <Setter Property="Background" Value="#FFD3FFB0"/>
                    <Setter Property="Opacity" Value="0.95"/>
                    <Setter Property="Panel.ZIndex" Value="5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="TabInnerTemplate">
            <Grid Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- ICONO INCÓGNITO -->
                <Path Grid.Column="0"
                      Width="14" Height="14"
                      Margin="0,0,4,0"
                      Fill="{DynamicResource IncognitoTextBrush}"
                      StrokeThickness="0.1"
                      Data="M2.54 1.22C2.66.52 3.27 0 3.98 0h6.04c.71 0 1.32.52 1.44 1.22l.71 4.28h1.05c.41 0 .75.34.75.75s-.34.75-.75.75H.78c-.41 0-.75-.34-.75-.75s.34-.75.75-.75h1.05l.71-4.28ZM8.75 10.9c0-.83.67-1.5 1.5-1.5.83 0 1.5.67 1.5 1.5 0 .83-.67 1.5-1.5 1.5-.83 0-1.5-.67-1.5-1.5Zm1.5-3c-1.06 0-2 .55-2.53 1.39-.22-.09-.46-.14-.72-.14-.26 0-.5.05-.72.14-.53-.83-1.47-1.39-2.53-1.39-1.66 0-3 1.34-3 3 0 1.66 1.34 3 3 3 1.66 0 3-1.34 3-3v-.01l.04-.13c.02-.04.03-.05.04-.06.01 0 .05-.03.16-.03.12 0 .16.03.16.03l.04.06.04.13v.04c.02 1.64 1.36 2.96 3 2.96 1.66 0 3-1.34 3-3 0-1.66-1.34-3-3-3ZM3.75 9.4c.82 0 1.48.65 1.5 1.46v.03c0 .01 0 .03.01.03-.02.81-.68 1.47-1.5 1.47-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5Z">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsIncognito}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
                <!-- FAVICON -->
                <Grid Grid.Column="1" Width="16" Height="16">
                    <Image Width="16" Height="16" Margin="0"
                           Source="{Binding FaviconUrl, Converter={StaticResource FaviconConverter}}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>
                <!-- TEXTO -->
                <TextBlock Grid.Column="2"
                           Margin="6,0,0,0"
                           Text="{Binding Title}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TabTextBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsIncognito}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource IncognitoTextBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DataTemplate>

        <!-- Contenido interno de la pestaña -->
        <DataTemplate x:Key="TabItemTemplate">
            <Grid Background="Transparent" ContextMenu="{StaticResource SharedContextMenu}" 
                  ContextMenuOpening="AbrirMenuCompartido" ClipToBounds="True">
                <Grid VerticalAlignment="Top" Margin="0" Panel.ZIndex="998" ClipToBounds="False">
                    <Border Height="3"
                            Background="{Binding MarkColor}"
                            HorizontalAlignment="Stretch"
                            Margin="6,0,6,0"
                            CornerRadius="5,5,0,0"/>
                </Grid>
                <Border x:Name="TabRoot"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        RenderTransformOrigin="0.5,0.5"
                        MinWidth="60"
                        PreviewMouseLeftButtonDown="TabItem_MouseDown"
                        PreviewMouseMove="TabItem_MouseMove"
                        PreviewMouseLeftButtonUp="TabItem_MouseUp">
                    <ContentControl Style="{StaticResource TabItemContainerStyle}"
                                    Content="{Binding}"
                                    ContentTemplate="{StaticResource TabInnerTemplate}"
                                    HorizontalContentAlignment="Stretch"/>
                </Border>
                <!-- OVERLAY DE CARGA -->
                <Border HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Background="#FF90FF90"
                        CornerRadius="8,8,0,0"
                        Panel.ZIndex="997"
                        Margin="3,0,3,0"
                        IsHitTestVisible="False">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Height" Value="0"/>
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                 From="0" To="28" Duration="0:0:0.8">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From=".8" To="0" Duration="0:0:0.8">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Height" To="0" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <!-- BOTÓN X CERRAR -->
                <Button x:Name="CloseButton"
                        Width="16" Height="16"
                        Background="Transparent"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="0,0,5,0"
                        Click="CloseTab_Click"
                        Cursor="Hand"
                        Panel.ZIndex="999">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid Width="16" Height="16">
                                <Ellipse Fill="{DynamicResource ButtonHoverBrush}" Width="16" Height="16"/>
                                <Path Data="M 5.2 5.2 L 10.8 10.8 M 10.8 5.2 L 5.2 10.8"
                                  Stroke="{DynamicResource TabTextBrush}"
                                  StrokeThickness="1.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </DataTemplate>

    </Window.Resources>



    <Border x:Name="_outerBorder" BorderBrush="Transparent" BorderThickness="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="13" ShadowDepth="0" Opacity="0.25" Color="black"/>
        </Border.Effect>

        <Border BorderBrush="#AAAAAA" BorderThickness="1">
            <Grid>

                <!-- POPUP ÚNICO DE FAVORITOS COMPARTIDO -->
                <Popup x:Name="PopupFavorites"
                       Placement="Top"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="White"
                            CornerRadius="5"
                            Padding="6"
                            BorderBrush="#CCC"
                            BorderThickness="1">
                        <StackPanel Orientation="Vertical">
                            <Button Width="170" Height="30" Margin="0 0 0 4" Click="BtnAddFavorite_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="Padding" Value="8 0"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F0F4FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Fill="{DynamicResource ButtonAccentBrush}"
                                          Data="M13 4.5 L15.8 9.7 L21.2 10.6 L17.1 14.9 L18.0 20.4 L13 17.3 L8 20.4 L8.9 14.9 L4.8 10.6 L10.2 9.7 Z"
                                          Width="14" Height="14"
                                          Stretch="Fill"
                                          Margin="0 0 8 0"/>
                                    <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_FavAdd}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_FavManage}"
                                    Width="170" Height="30"
                                    Click="BtnOpenFavorites_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="Padding" Value="8 0"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F0F4FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>
                </Popup>


                <Grid x:Name="rootGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Background="{DynamicResource WindowBackgroundBrush}"
                               Height="40"
                               MouseLeftButtonDown="TopBar_MouseLeftButtonDown">

                        <!-- TÍTULO (izquierda) -->
                        <DockPanel Margin="10,0,0,0">
                            <!-- Ícono -->
                            <Path
                            DockPanel.Dock="Left"
                            Data="m 88.867,179.274 c -4.825,-12.714 -8.773,-23.311 -8.773,-23.547 0,-0.489 0.409,-0.573 0.677,-0.139 0.398,0.645 4.24,2.906 6.278,3.694 6.712,2.598 15.093,2.598 21.806,0 2.037,-0.788 5.879,-3.049 6.278,-3.694 0.264,-0.428 0.677,-0.353 0.677,0.123 0,0.805 -17.549,46.681 -17.857,46.681 -0.172,0 -4.261,-10.403 -9.086,-23.118 z M 117.399,153.609 c 0,-0.2 0.179,-0.513 0.399,-0.696 0.65,-0.539 2.727,-4.023 3.429,-5.75 3.572,-8.792 2.454,-20.372 -2.634,-27.284 -0.657,-0.893 -1.195,-1.697 -1.195,-1.786 0,-0.089 0.289,-0.107 0.643,-0.039 1.468,0.28 46.452,17.54 46.452,17.823 0,0.169 -1.279,0.789 -2.844,1.377 -1.564,0.588 -12.114,4.59 -23.444,8.895 -11.33,4.304 -20.646,7.825 -20.703,7.825 -0.056,0 -0.103,-0.164 -0.103,-0.364 z M 68.054,150.107 c -5.093,-1.952 -12.356,-4.724 -16.139,-6.16 -3.783,-1.435 -9.945,-3.774 -13.692,-5.197 -3.747,-1.423 -6.813,-2.72 -6.813,-2.882 0,-0.162 5.447,-2.361 12.104,-4.887 36.99,-14.033 34.991,-13.298 34.991,-12.859 0,0.071 -0.413,0.672 -0.919,1.335 -3.33,4.363 -4.983,9.863 -4.967,16.526 0.01,4.123 0.581,7.358 1.901,10.77 0.788,2.037 3.049,5.879 3.694,6.278 0.495,0.305 0.32,0.678 -0.304,0.651 -0.327,-0.014 -4.762,-1.623 -9.855,-3.575 z m 27.781,1.847 c -6.27,-0.965 -11.688,-5.662 -13.451,-11.663 -2.492,-8.483 2.822,-17.782 11.466,-20.062 2.08,-0.548 5.688,-0.612 7.672,-0.135 6.479,1.557 11.252,6.681 12.364,13.272 0.37,2.198 0.37,2.675 -0.0005,4.946 -1.024,6.271 -5.49,11.341 -11.561,13.126 -1.502,0.441 -5.11,0.728 -6.49,0.516 z M 80.093,115.987 c 0,-0.768 17.56,-46.68 17.854,-46.68 0.271,0 17.533,45.042 17.802,46.453 0.158,0.829 -0.047,0.809 -1.223,-0.116 -2.754,-2.169 -6.233,-3.689 -10.411,-4.548 -3.852,-0.792 -10.27,-0.632 -13.981,0.349 -3.05,0.806 -5.964,2.151 -8.153,3.763 -1.813,1.335 -1.887,1.365 -1.887,0.78 z"
                            Fill="{DynamicResource WindowForegroundBrush}"
                            Width="24"
                            Height="24"
                            Margin="0,2,3,0" RenderTransformOrigin="0.72,0.54" Stretch="Fill"/>

                            <!-- Texto -->
                            <TextBlock
                                DockPanel.Dock="Left"
                                Text="Multinavigator 7"
                                VerticalAlignment="Center"
                                Margin="0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource WindowForegroundBrush}"/>
                        </DockPanel>


                        <!-- BOTONES SISTEMA (derecha) -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Stretch">

                            <!-- MINIMIZAR -->
                            <Button Click="BtnMinimize_Click" Width="46" VerticalAlignment="Stretch"
                                    BorderThickness="0" Background="Transparent">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid>
