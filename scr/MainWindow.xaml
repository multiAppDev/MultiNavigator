                                    </ItemsControl>
                                </ScrollViewer>
                                <Button Grid.Column="2" Width="28" Height="28" Background="Transparent" BorderThickness="0"
                                        Click="AddTab4_Click" Style="{StaticResource DefaultButtonStyle}" Cursor="Hand">
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="24" Height="24">
                                        <Path Fill="White" Data="M10,0 A10,10 0 1 1 9.999,0.001" Margin="3,3,3,3" Stretch="Fill"/>
                                        <Path Stroke="{DynamicResource ButtonAccentBrush}" StrokeThickness="2.5"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Data="M 10,4 V 16 M 4,10 H 16" Margin="7,7,7,7" Stretch="Fill"/>
                                    </Grid>
                                </Button>
                                <Border x:Name="BtnScrollRight4" Tag="4" Grid.Column="3" Width="20" Height="28"
                                        Background="Transparent" BorderThickness="0" CornerRadius="0 10 10 0"
                                        MouseEnter="ScrollRight_MouseEnter" MouseLeave="ScrollButtons_MouseLeave"
                                        MouseLeftButtonUp="BtnScrollRight_Click">
                                    <Canvas Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Stroke="#FF4B96EA" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Data="M 6,5 L 14,10 L 6,15"/>
                                    </Canvas>
                                </Border>
                            </Grid>
                            <ContentControl x:Name="NavBar4" Grid.Row="1" Content="1"
                                            Style="{StaticResource NavBarStyle}"
                                            ContentTemplate="{StaticResource NavigationBarTemplate}"/>
                            <Grid Grid.Row="2" Background="white" x:Name="WebHost4"/>
                        </Grid>

                        <!-- BOTÓN CENTRAL + INDICADOR DROP -->
                        <Canvas x:Name="canvasBoton"
                                Grid.RowSpan="2" Grid.ColumnSpan="2"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                ClipToBounds="True" Panel.ZIndex="999">

                            <Border x:Name="ghostTab"
                                    Background="#AAFFFFFF"
                                    BorderBrush="Black" BorderThickness="1"
                                    Padding="10" Visibility="Collapsed"
                                    CornerRadius="4" Panel.ZIndex="2000" Cursor="SizeAll">
                                <TextBlock x:Name="ghostTabText" FontWeight="Bold" Foreground="Black"/>
                            </Border>

                            <Path x:Name="botonCentral"
                                  Width="84" Height="84"
                                  Cursor="SizeAll"
                                  Fill="{DynamicResource ButtonCentroBrush}"
                                  Stretch="Uniform"
                                  Canvas.Left="558" Canvas.Top="341.04"
                                  MouseLeftButtonDown="BotonCentral_MouseLeftButtonDown">
                                <Path.Data>
                                    <GeometryGroup>
                                        <EllipseGeometry Center="42,42" RadiusX="7.5" RadiusY="7.5"/>
                                        <PathGeometry Figures="M42,2 L46,31 C44,29 40,29 38,31 Z"/>
                                        <PathGeometry Figures="M42,82 L46,53 C44,55 40,55 38,53 Z"/>
                                        <PathGeometry Figures="M82,42 L53,46 C55,44 55,40 53,38 Z"/>
                                        <PathGeometry Figures="M2,42 L31,46 C29,44 29,40 31,38 Z"/>
                                    </GeometryGroup>
                                </Path.Data>
                            </Path>

                            <Rectangle x:Name="dropIndicator"
                                       Width="3" Fill="Red" Height="100"
                                       Visibility="Collapsed"
                                       Canvas.Left="0" Canvas.Top="0"
                                       Panel.ZIndex="3000"/>
                        </Canvas>

                    </Grid>

                </Grid>

                <Popup x:Name="PopupBienvenida"
PlacementTarget="{Binding ElementName=BtnHamburguesa}"
Placement="Bottom"
StaysOpen="False"
AllowsTransparency="True">
                    <Grid Margin="10,8,10,10">
                        <Border CornerRadius="10" Background="#ffffDD"
         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
         Margin="0,8,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.25" Direction="270"/>
                            </Border.Effect>
                            <StackPanel Margin="14,12">
                                <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_WelcomePopup}"
                    Foreground="Black"
                    FontWeight="SemiBold"
                    FontSize="13"/>
                            </StackPanel>
                        </Border>
                        <Path Data="M 0,8 L 8,0 L 16,8"
       Fill="#ffffDD"
       Stroke="{DynamicResource BorderBrush}"
       StrokeThickness="1"
       HorizontalAlignment="Right"
       VerticalAlignment="Top"
       Margin="0,0,10,0"/>
                    </Grid>
                </Popup>

                <!-- Popup flotante para el ghost -->
                <Popup x:Name="GhostPopup"
                       AllowsTransparency="True"
                       IsOpen="False"
                       Placement="AbsolutePoint"
                       StaysOpen="True"
                       IsHitTestVisible="False">
                    <local:DragGhostControl x:Name="Ghost"/>
                </Popup>

                <!-- POPUP DE PERMISOS -->
                <Popup x:Name="PopupPermisos"
                       Placement="Absolute"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="White" CornerRadius="4" Padding="10"
                            BorderBrush="#CCC" BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="TxtPermisoMensaje" FontWeight="Bold" Margin="0 0 0 10"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnPermitir"
                                        Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_PermAllow}"
                                        Margin="0 0 10 0"
                                        Click="BtnPermitir_Click"/>
                                <Button x:Name="BtnBloquear"
                                        Content="{Binding Source={StaticResource IdiomaGlobal}, Path=Main_PermBlock}"
                                        Click="BtnBloquear_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>

                <Popup x:Name="PopupSugerencias"
                       PlacementTarget="{Binding ElementName=BtnHamburguesa}"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="White" BorderBrush="#CCC" BorderThickness="1"
                            CornerRadius="0,0,8,8" MaxHeight="300" MinWidth="400">
                        <ListBox x:Name="ListaSugerencias"
                                 BorderThickness="0"
                                 SelectionChanged="ListaSugerencias_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="5" Cursor="Hand">
                                        <Image Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Image.Source>
                                                <Binding Path="Url">
                                                    <Binding.Converter>
                                                        <local:UrlToFaviconConverter/>
                                                    </Binding.Converter>
                                                </Binding>
                                            </Image.Source>
                                        </Image>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Url}" Foreground="#666" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>

            </Grid>
        </Border>

    </Border>

</Window>
