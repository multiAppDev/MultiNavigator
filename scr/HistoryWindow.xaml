<Window x:Class="Multinavigator.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Multinavigator"
        xmlns:res="clr-namespace:Multinavigator.Idiomas"
        Title="{Binding Source={StaticResource IdiomaGlobal}, Path=History_WindowTitle}"
        Height="650" Width="850"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Background="#F5F5F5">

    <Window.Resources>
        <local:UrlToFaviconConverter x:Key="UrlToFaviconConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Background="White" BorderBrush="#DDD" BorderThickness="0 0 0 1">
            <DockPanel Margin="20 0">
                <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=History_Title}"
                           FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0 0 20 0"/>
                <Border Background="#F0F0F0" CornerRadius="15" Padding="10 0"
                        VerticalAlignment="Center" Width="350">
                    <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                             Height="30" VerticalAlignment="Center" VerticalContentAlignment="Center"
                             FontSize="13" TextChanged="SearchBox_TextChanged"/>
                </Border>
            </DockPanel>
        </Border>

        <!-- GRUPOS CON EXPANDER -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GroupsPanel">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="{Binding IsExpanded}" Margin="0 4 0 0">
                            <Expander.Header>
                                <Border Background="#EEEEEE" Padding="15 6" Width="800">
                                    <DockPanel>
                                        <TextBlock Text="{Binding GroupName}" FontWeight="Bold"
                                                   FontSize="12" Foreground="#555"/>
                                        <TextBlock Text="{Binding Count, StringFormat='({0})'}"
                                                   FontSize="11" Foreground="#AAA"
                                                   Margin="8 0 0 0" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>
                            </Expander.Header>
                            <ItemsControl ItemsSource="{Binding Entries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#EEEEEE" BorderThickness="0 0 0 1"
                                                Padding="20 3" Background="White">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F0F4FF"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="50"/>
                                                </Grid.ColumnDefinitions>

                                                <Image Width="14" Height="14" VerticalAlignment="Center">
                                                    <Image.Source>
                                                        <Binding Path="Url" Converter="{StaticResource UrlToFaviconConverter}"/>
                                                    </Image.Source>
                                                </Image>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8 0">
                                                    <TextBlock Text="{Binding Title}" FontSize="12"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Url}" FontSize="10"
                                                               Foreground="#888" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                           FontSize="10" Foreground="#AAA"
                                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                                <Button Grid.Column="3" Content="✕" Tag="{Binding}"
                                                        Click="DeleteEntry_Click"
                                                        Width="24" Height="18" FontSize="10"
                                                        Margin="5 0 0 0" Background="Transparent"
                                                        BorderThickness="0" Foreground="#AAA"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- PIE -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="0 1 0 0">
            <DockPanel Margin="20 0">
                <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=History_IncognitoNote}"
                           Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=History_DeleteAll}"
                        DockPanel.Dock="Right" Height="30" Padding="12 0"
                        Background="#C62828" Foreground="White" BorderThickness="0"
                        VerticalAlignment="Center" Click="DeleteAll_Click"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
