<Window x:Class="Multinavigator.EditCookieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:Multinavigator.Idiomas"
        Title="{Binding Source={StaticResource IdiomaGlobal}, Path=EditCookie_WindowTitle}"
        Height="420" Width="450"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FAFAFA">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=EditCookie_Name}" FontWeight="Bold"/>
            <TextBlock x:Name="NameTextBlock" Margin="0 0 0 10"/>

            <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=EditCookie_Value}" FontWeight="Bold"/>
            <TextBox x:Name="ValueTextBox" Height="60" TextWrapping="Wrap" Margin="0 0 0 10"/>

            <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=EditCookie_Path}" FontWeight="Bold"/>
            <TextBox x:Name="PathTextBox" Margin="0 0 0 10"/>

            <TextBlock Text="{Binding Source={StaticResource IdiomaGlobal}, Path=EditCookie_Expires}" FontWeight="Bold"/>
            <DatePicker x:Name="ExpiresDatePicker" Margin="0 0 0 10"/>

            <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                <CheckBox x:Name="SecureCheckBox"   Content="Secure"   Margin="0 0 15 0"/>
                <CheckBox x:Name="HttpOnlyCheckBox" Content="HttpOnly" Margin="0 0 15 0"/>
                <CheckBox x:Name="SessionCheckBox"  Content="Session"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0 15 0 0">
            <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=EditCookie_Save}"
                    Width="90" Padding="8 4" Margin="0 0 10 0"
                    Background="#5CB85C" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="SaveButton_Click"/>
            <Button Content="{Binding Source={StaticResource IdiomaGlobal}, Path=EditCookie_Cancel}"
                    Width="90" Padding="8 4"
                    Background="#777" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
